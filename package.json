{
  "name": "mf-react-webpack",
  "version": "0.0.1",
  "scripts": {
    "start": "concurrently \"pnpm --filter=./app1 start\" \"pnpm --filter=./app2 start\" \"pnpm --filter=./app3 start\"",
    "build": "pnpm --filter=./app3 build && pnpm --filter=./app2 build && pnpm --filter=./app1 build",
    "start:dev": "concurrently \"pnpm --filter=./app1 start:dev\" \"pnpm --filter=./app2 start:dev\" \"pnpm --filter=./app3 start:dev\"",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1"
  }
}
